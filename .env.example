PORT=3000
NODE_ENV=production

# Supabase Configurations
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_secret_key

# Default MikroTik connection (optional, can add more via UI)
MIKROTIK_HOST=192.168.88.1
MIKROTIK_USER=admin
MIKROTIK_PASS=
MIKROTIK_PORT=8728
# Demo mode: set to true to use simulated data without real MikroTik
DEMO_MODE=true
